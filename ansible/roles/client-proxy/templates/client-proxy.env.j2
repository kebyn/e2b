# E2B Client Proxy 环境变量

NODE_ID=proxy-{{ inventory_hostname }}
ENVIRONMENT={{ environment }}

# Redis
# ⚠️ 格式：host:port，不支持 redis:// 前缀
# ⚠️ 源码不支持 Sentinel 客户端；如使用 Sentinel，需在前面挂 HAProxy 暴露单一端点
REDIS_URL={{ redis_host | default(hostvars[groups['redis_master'][0]]['ansible_host']) }}:{{ redis_port }}

# API 地址
API_INTERNAL_GRPC_ADDRESS={{ api_internal_grpc_address | default(api_domain ~ ':' ~ (api_internal_grpc_port | default(5009))) }}
{% if api_edge_grpc_address | default('') %}
API_EDGE_GRPC_ADDRESS={{ api_edge_grpc_address }}
API_EDGE_GRPC_OAUTH_CLIENT_ID={{ api_edge_grpc_oauth_client_id }}
API_EDGE_GRPC_OAUTH_CLIENT_SECRET={{ api_edge_grpc_oauth_client_secret }}
API_EDGE_GRPC_OAUTH_TOKEN_URL={{ api_edge_grpc_oauth_token_url }}
{% endif %}

# 端口
PROXY_PORT={{ proxy_port }}
HEALTH_PORT={{ proxy_health_port }}

# ClickHouse (可选)
{% if clickhouse_enabled %}
CLICKHOUSE_CONNECTION_STRING=clickhouse://{{ clickhouse_user }}:{{ clickhouse_password }}@{{ hostvars[groups['clickhouse'][0]]['ansible_host'] }}:{{ clickhouse_port }}/{{ clickhouse_database }}
{% endif %}

# Loki (可选)
{% if loki_enabled %}
LOKI_URL=http://{{ hostvars[groups['loki'][0]]['ansible_host'] }}:{{ loki_port }}
{% endif %}
