# E2B Orchestrator Nomad 任务

job "e2b-orchestrator" {
  datacenters = ["{{ nomad_datacenter }}"]
  type        = "system"
  node_pool   = "{{ orchestrator_nomad_node_pool }}"

  group "orchestrator" {
    network {
      port "grpc"  { static = {{ orchestrator_grpc_port }} }
      port "proxy" { static = {{ orchestrator_proxy_port }} }
    }

    service {
      name     = "orchestrator"
      port     = "grpc"
      provider = "nomad"

      check {
        type     = "http"
        path     = "/health"
        interval = "20s"
        timeout  = "5s"
      }
    }

    service {
      name     = "orchestrator-proxy"
      port     = "proxy"
      provider = "nomad"

      check {
        type     = "tcp"
        interval = "30s"
        timeout  = "2s"
      }
    }

    task "orchestrator" {
      driver = "raw_exec"

      config {
        command = "/usr/local/bin/orchestrator"
      }

      env {
        NODE_ID                     = "${node.unique.name}"
        NODE_IP                     = "${attr.unique.network.ip-address}"
        ENVIRONMENT                 = "{{ e2b_environment }}"
        ORCHESTRATOR_SERVICES       = "orchestrator"
        # ⚠️ 格式：host:port，不支持 redis:// 前缀；Sentinel 需挂 HAProxy
        REDIS_URL                   = "{{ redis_effective_url }}"
        REDIS_CLUSTER_URL           = "{{ redis_cluster_url }}"
        REDIS_TLS_CA_BASE64         = "{{ redis_tls_ca_base64 }}"
        REDIS_POOL_SIZE             = "{{ orchestrator_redis_pool_size }}"
        REDIS_MIN_IDLE_CONNS        = "{{ orchestrator_redis_min_idle_conns }}"
        TEMPLATE_BUCKET_NAME        = "{{ template_bucket_name }}"
        BUILD_CACHE_BUCKET_NAME     = "{{ build_cache_bucket_name }}"
        STORAGE_PROVIDER            = "{{ storage_provider }}"
        ARTIFACTS_REGISTRY_PROVIDER = "{{ artifacts_registry_provider }}"
        PROVIDER                    = "{{ orchestrator_provider }}"
        GOOGLE_SERVICE_ACCOUNT_BASE64 = "{{ google_service_account_base64 }}"
        GCP_PROJECT_ID              = "{{ gcp_project_id }}"
        GCP_REGION                  = "{{ gcp_region }}"
        GCP_DOCKER_REPOSITORY_NAME  = "{{ gcp_docker_repository_name }}"
        LOCAL_TEMPLATE_STORAGE_BASE_PATH = "{{ local_template_storage_base_path }}"
        LOCAL_BUILD_CACHE_STORAGE_BASE_PATH = "{{ local_build_cache_storage_base_path }}"
        AWS_ENDPOINT_URL            = "{{ aws_endpoint_url }}"
        S3_USE_PATH_STYLE           = "{{ s3_use_path_style }}"
        DEFAULT_FIRECRACKER_VERSION = "{{ default_firecracker_version }}"
        DEFAULT_KERNEL_VERSION      = "{{ default_kernel_version }}"
        BUSYBOX_VERSION             = "{{ busybox_version }}"
        DOMAIN_NAME                 = "{{ domain_name }}"
        LAUNCH_DARKLY_API_KEY       = "{{ launchdarkly_api_key }}"
        USE_LOCAL_NAMESPACE_STORAGE = "true"
        ORCHESTRATOR_BASE_PATH      = "{{ e2b_orchestrator_path }}"
        SANDBOX_DIR                 = "{{ e2b_fc_vm_dir }}"
        HOST_KERNELS_DIR            = "{{ e2b_kernels_dir }}"
        FIRECRACKER_VERSIONS_DIR    = "{{ e2b_firecracker_dir }}"
        HOST_ENVD_PATH              = "{{ e2b_envd_path }}"
        HOST_BUSYBOX_DIR            = "{{ e2b_busybox_dir | default(e2b_base_dir + '/busybox') }}"
        SHARED_CHUNK_CACHE_PATH     = "{{ e2b_orchestrator_path }}/cache"
        GRPC_PORT                   = "{{ orchestrator_grpc_port }}"
        PROXY_PORT                  = "{{ orchestrator_proxy_port }}"
        {% if clickhouse_enabled %}
        CLICKHOUSE_CONNECTION_STRING = "clickhouse://{{ clickhouse_user | urlencode | replace('/', '%2F') }}:{{ clickhouse_password | urlencode | replace('/', '%2F') }}@{{ hostvars[groups['clickhouse'][0]]['ansible_host'] }}:{{ clickhouse_port }}/{{ clickhouse_database | urlencode | replace('/', '%2F') }}"
        {% endif %}
        CLICKHOUSE_CONNECTION_STRINGS = "{{ clickhouse_connection_strings | default([]) | join(';') }}"
        {% if loki_enabled %}
        LOKI_URL                    = "http://{{ hostvars[groups['loki'][0]]['ansible_host'] }}:{{ loki_port }}"
        {% endif %}
      }

      resources {
        cpu        = 4000
        memory     = 1024
        memory_max = -1
      }
    }
  }
}
