# E2B API 环境变量

NODE_ID=api-{{ inventory_hostname }}
ENVIRONMENT={{ environment }}

# 数据库
POSTGRES_CONNECTION_STRING=postgresql://{{ postgres_user }}:{{ postgres_password }}@{{ hostvars[groups['postgresql'] | selectattr('pg_role', 'equalto', 'primary') | first]['ansible_host'] }}:{{ postgres_port }}/{{ postgres_database }}?sslmode=disable

# Redis
# ⚠️ 格式：host:port，不支持 redis:// 前缀
# ⚠️ 源码不支持 Sentinel 客户端；如使用 Sentinel，需在前面挂 HAProxy 暴露单一端点
REDIS_URL={{ redis_host | default(hostvars[groups['redis_master'][0]]['ansible_host']) }}:{{ redis_port }}

# 服务发现
SERVICE_DISCOVERY_PROVIDER={{ service_discovery_provider | default('nomad') }}
NOMAD_ADDRESS=http://{{ hostvars[groups['nomad_server'][0]]['ansible_host'] }}:4646
NOMAD_TOKEN={{ hostvars[groups['nomad_server'][0]]['nomad_acl_token'] | default('') }}
NOMAD_ORCHESTRATOR_SERVICE_NAMES={{ nomad_orchestrator_service_names | default('orchestrator') }}
NOMAD_ORCHESTRATOR_LEGACY_DISCOVERY_ENABLED={{ nomad_orchestrator_legacy_discovery_enabled | default(true) | lower }}
K8S_NAMESPACE={{ k8s_namespace | default('default') }}
K8S_ORCHESTRATOR_POD_LABEL_SELECTOR={{ k8s_orchestrator_pod_label_selector | default('app.kubernetes.io/name=orchestrator') }}
K8S_TEMPLATE_MANAGER_POD_LABEL_SELECTOR={{ k8s_template_manager_pod_label_selector | default('app.kubernetes.io/name=template-manager') }}
LOCAL_ORCHESTRATOR_ADDRESS={{ local_orchestrator_address | default('127.0.0.1:5008') }}

# 模板存储
TEMPLATE_BUCKET_NAME={{ template_bucket_name }}
BUILD_CACHE_BUCKET_NAME={{ build_cache_bucket_name }}
STORAGE_PROVIDER={{ storage_provider }}
GOOGLE_SERVICE_ACCOUNT_BASE64={{ google_service_account_base64 }}

# 认证
ADMIN_TOKEN={{ admin_token }}
AUTH_PROVIDER_CONFIG={{ auth_provider_config | default('{"jwt":[]}') }}

# 端口
API_INTERNAL_GRPC_PORT={{ api_internal_grpc_port | default(5009) }}
API_EDGE_GRPC_PORT={{ api_edge_grpc_port | default(5109) }}

# 域名
DOMAIN_NAME={{ domain_name }}

# ClickHouse (可选)
{% if clickhouse_enabled %}
CLICKHOUSE_CONNECTION_STRING=clickhouse://{{ clickhouse_user }}:{{ clickhouse_password }}@{{ hostvars[groups['clickhouse'][0]]['ansible_host'] }}:{{ clickhouse_port }}/{{ clickhouse_database }}
{% endif %}

# Loki（变量必须存在，值可为空以禁用日志收集）
{% if loki_enabled %}
LOKI_URL=http://{{ hostvars[groups['loki'][0]]['ansible_host'] }}:{{ loki_port }}
{% else %}
LOKI_URL=
{% endif %}

# Volume Token
VOLUME_TOKEN_ISSUER={{ volume_token_issuer }}
VOLUME_TOKEN_SIGNING_METHOD={{ volume_token_signing_method }}
VOLUME_TOKEN_SIGNING_KEY={{ volume_token_signing_key }}
VOLUME_TOKEN_SIGNING_KEY_NAME={{ volume_token_signing_key_name }}
