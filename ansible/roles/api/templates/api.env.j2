# E2B API 环境变量

NODE_ID=api-{{ inventory_hostname }}
ENVIRONMENT={{ e2b_environment }}

# 数据库
POSTGRES_CONNECTION_STRING={{ postgres_connection_string }}

# Redis
# ⚠️ 格式：host:port，不支持 redis:// 前缀
# ⚠️ 源码不支持 Sentinel 客户端；如使用 Sentinel，需在前面挂 HAProxy 暴露单一端点
REDIS_URL={{ redis_effective_url }}
REDIS_CLUSTER_URL={{ redis_cluster_url }}
REDIS_TLS_CA_BASE64={{ redis_tls_ca_base64 }}
REDIS_POOL_SIZE={{ api_redis_pool_size }}

# 服务发现
SERVICE_DISCOVERY_PROVIDER={{ service_discovery_provider | default('nomad') }}
NOMAD_ADDRESS=http://{{ hostvars[groups['nomad_server'][0]]['ansible_host'] }}:4646
NOMAD_TOKEN={{ hostvars[groups['nomad_server'][0]]['nomad_acl_token'] | default(nomad_effective_token | default(nomad_token | default(''))) }}
NOMAD_ORCHESTRATOR_SERVICE_NAMES={{ nomad_orchestrator_service_names | default('orchestrator') }}
NOMAD_ORCHESTRATOR_LEGACY_DISCOVERY_ENABLED={{ nomad_orchestrator_legacy_discovery_enabled | default(true) | lower }}
K8S_NAMESPACE={{ k8s_namespace | default('default') }}
K8S_ORCHESTRATOR_POD_LABEL_SELECTOR={{ k8s_orchestrator_pod_label_selector | default('app.kubernetes.io/name=orchestrator') }}
K8S_TEMPLATE_MANAGER_POD_LABEL_SELECTOR={{ k8s_template_manager_pod_label_selector | default('app.kubernetes.io/name=template-manager') }}
LOCAL_ORCHESTRATOR_ADDRESS={{ local_orchestrator_address | default('127.0.0.1:5008') }}

# 模板存储
TEMPLATE_BUCKET_NAME={{ template_bucket_name }}
BUILD_CACHE_BUCKET_NAME={{ build_cache_bucket_name }}
STORAGE_PROVIDER={{ storage_provider }}
GOOGLE_SERVICE_ACCOUNT_BASE64={{ google_service_account_base64 }}
GCP_PROJECT_ID={{ gcp_project_id }}
GCP_REGION={{ gcp_region }}
GCP_DOCKER_REPOSITORY_NAME={{ gcp_docker_repository_name }}
LOCAL_TEMPLATE_STORAGE_BASE_PATH={{ local_template_storage_base_path }}
LOCAL_BUILD_CACHE_STORAGE_BASE_PATH={{ local_build_cache_storage_base_path }}
AWS_ENDPOINT_URL={{ aws_endpoint_url }}
S3_USE_PATH_STYLE={{ s3_use_path_style }}
DEFAULT_FIRECRACKER_VERSION={{ default_firecracker_version }}
DEFAULT_KERNEL_VERSION={{ default_kernel_version }}

# 认证
ADMIN_TOKEN={{ admin_token | to_json }}
AUTH_PROVIDER_CONFIG={{ auth_provider_config | default('{"jwt":[]}') | to_json }}
SANDBOX_ACCESS_TOKEN_HASH_SEED={{ sandbox_access_token_hash_seed | to_json }}
LAUNCH_DARKLY_API_KEY={{ launchdarkly_api_key | to_json }}

# 端口
API_INTERNAL_GRPC_PORT={{ api_internal_grpc_port | default(5009) }}
API_EDGE_GRPC_PORT={{ api_edge_grpc_port | default(5109) }}

# 域名
DOMAIN_NAME={{ domain_name }}

# ClickHouse (可选)
{% if clickhouse_enabled %}
CLICKHOUSE_CONNECTION_STRING=clickhouse://{{ clickhouse_user | urlencode | replace('/', '%2F') }}:{{ clickhouse_password | urlencode | replace('/', '%2F') }}@{{ hostvars[groups['clickhouse'][0]]['ansible_host'] }}:{{ clickhouse_port }}/{{ clickhouse_database | urlencode | replace('/', '%2F') }}
{% endif %}
CLICKHOUSE_CONNECTION_STRINGS={{ clickhouse_connection_strings | default([]) | join(';') }}

# Loki（变量必须存在，值可为空以禁用日志收集）
{% if loki_enabled %}
LOKI_URL=http://{{ hostvars[groups['loki'][0]]['ansible_host'] }}:{{ loki_port }}
{% else %}
LOKI_URL=
{% endif %}

# Volume Token
VOLUME_TOKEN_ISSUER={{ volume_token_issuer | to_json }}
VOLUME_TOKEN_SIGNING_METHOD={{ volume_token_signing_method }}
VOLUME_TOKEN_SIGNING_KEY={{ volume_token_signing_key | to_json }}
VOLUME_TOKEN_SIGNING_KEY_NAME={{ volume_token_signing_key_name | to_json }}
