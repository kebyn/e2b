# E2B Dashboard API 环境变量

NODE_ID=dashboard-api-{{ inventory_hostname }}
ENVIRONMENT={{ e2b_environment }}
PORT={{ dashboard_api_port }}

# 数据库
POSTGRES_CONNECTION_STRING={{ postgres_connection_string }}

# 认证 (Dashboard 必需)
ADMIN_TOKEN={{ admin_token | to_json }}
AUTH_PROVIDER_CONFIG={{ auth_provider_config | default('{"jwt":[]}') | to_json }}
ORY_SDK_URL={{ ory_sdk_url | to_json }}
ORY_PROJECT_API_TOKEN={{ ory_project_api_token | to_json }}
ORY_ISSUER_URL={{ ory_issuer_url | to_json }}
DOMAIN_NAME={{ domain_name | to_json }}

# Redis（必需，至少配置 REDIS_URL 或 REDIS_CLUSTER_URL 之一）
# ⚠️ 格式：host:port，不支持 redis:// 前缀
REDIS_URL={{ redis_effective_url }}
REDIS_CLUSTER_URL={{ redis_cluster_url }}
REDIS_TLS_CA_BASE64={{ redis_tls_ca_base64 }}

# Auth DB (可选，默认同 POSTGRES)
# AUTH_DB_CONNECTION_STRING=postgresql://...
# AUTH_DB_READ_REPLICA_CONNECTION_STRING=postgresql://...

# ClickHouse (可选)
{% if clickhouse_enabled %}
CLICKHOUSE_CONNECTION_STRING=clickhouse://{{ clickhouse_user | urlencode | replace('/', '%2F') }}:{{ clickhouse_password | urlencode | replace('/', '%2F') }}@{{ hostvars[groups['clickhouse'][0]]['ansible_host'] }}:{{ clickhouse_port }}/{{ clickhouse_database | urlencode | replace('/', '%2F') }}
{% endif %}
CLICKHOUSE_CONNECTION_STRINGS={{ clickhouse_connection_strings | default([]) | join(';') }}

# Loki (可选)
{% if loki_enabled %}
LOKI_URL=http://{{ hostvars[groups['loki'][0]]['ansible_host'] }}:{{ loki_port }}
{% endif %}
